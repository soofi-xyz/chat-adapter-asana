{
  "name": "asana-chat-sdk-adapter",
  "version": "0.0.0",
  "private": true,
  "description": "Asana adapter for Chat SDK and companion AWS CDK construct, by soofi.xyz",
  "packageManager": "pnpm@9.15.9",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "clean": "pnpm -r run clean",
    "test": "pnpm -r --filter \"./packages/*\" run test",
    "typecheck": "pnpm -r --filter \"./packages/*\" run typecheck",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm -r --filter \"./packages/*\" run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.11",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "homepage": "https://soofi.xyz",
  "repository": {
    "type": "git",
    "url": "https://github.com/soofi/asana-chat-sdk-adapter"
  },
  "author": {
    "name": "soofi.xyz",
    "url": "https://soofi.xyz"
  }
}
